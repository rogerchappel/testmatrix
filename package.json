{
  "name": "testmatrix",
  "version": "0.1.0",
  "description": "Detect, classify, and run safe local verification commands with a result matrix.",
  "type": "module",
  "bin": {
    "testmatrix": "./bin/testmatrix.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "smoke": "npm run build && node ./bin/testmatrix.js --cwd fixtures/npm-safe --json --output .testmatrix/results.json",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run package:smoke"
  },
  "keywords": [
    "cli",
    "developer-tools",
    "testing",
    "ci",
    "local-first",
    "agentic-workflows"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
